# Database connection (Neon / Postgres). Provide a full connection string.
# Example (Neon):
# postgres://username:password@your-neon-host:5432/dbname?sslmode=require
DATABASE_URL=postgres://username:password@host:5432/dbname

# JWT secret used to sign authentication tokens. Use a long random string in production.
JWT_SECRET=97f57a0ce81830cdd1fe9e947ac48cbb319727d0845aea58d018f791b4f5546e

# SSL options for database connections. Many hosted Postgres providers (Neon) require SSL.
# Set to 'true' to enable SSL in the pg Pool configuration. If your provider uses a
# certificate that Node cannot verify, set DB_SSL_REJECT_UNAUTHORIZED=false.
DB_SSL=false
DB_SSL_REJECT_UNAUTHORIZED=false

# Optional: PGSSLMODE (e.g. 'require') will also enable SSL behavior if present in the URL.
PGSSLMODE=require

# NODE_ENV and PORT (useful for local development)
NODE_ENV=development
PORT=3000

# Optional: initial admin account seed values used on first boot if the database does not already contain the admin user.
# These defaults are safe for local development only.
SEED_ADMIN_EMAIL=Sukhpreet22@gmail.com
SEED_ADMIN_PASSWORD=Skill#4343

# Optional: restrict CORS Access-Control-Allow-Origin header. Defaults to '*' if not set.
# Set this to your production origin to be more secure, e.g. https://your-app.vercel.app
ALLOWED_ORIGIN=*

# When deploying on Vercel, set at minimum DATABASE_URL and JWT_SECRET in Project > Settings > Environment Variables.
# Do NOT commit real credentials to the repository. Use this file as a template.
